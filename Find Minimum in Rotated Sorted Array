# Find Minimum in Rotated Sorted Array (Leetcode-153)

#Brute Force solution
class Solution:
    def findMin(self, nums: List[int]) -> int:
           n=len(nums)
           mini=float("inf")
           for i in range(0,n):
               mini=min(nums[i],mini)
           return mini

#Time Complexity =O(N)
#Space Complexity=O(1)

#Optimal Solution

class Solution:
    def findMin(self, nums: List[int]) -> int:
           n=len(nums)
           mini=float("inf")
           low=0
           high=n-1
           while low<=high:
               mid=(low+high)//2
               if nums[mid]<=nums[high]:
                    mini=min(nums[mid],mini)
                    high=mid-1 
               else:
                 mini=min(nums[low],mini)
                 low=mid+1
         return mini

#Time Complexity=O(log N)
#Space Complxity=O(1)
