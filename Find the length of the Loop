#Find the Length of the Loop

#Brute force solution
class Solution:
    def lengthOfLoop(self, head):
       temp=head
       my_dict=dict()
       total=0
       while temp is not None:
          if temp in my_dict:
             return total-my_dict[temp]
          my_dict[temp]=total
          total+=1
          temp=temp.next
        return 0

#Time complexity=O(N)
#space Complexity=O(N)

#Optimal Solution

class Solution:
    def lengthOfLoop(self, head):
        slow=head
        fast=head
        while fast is not None and fast.next is not None:
                 slow=slow.next
                 fast=fast.next.next
                 if slow==fast:
                      slow=slow.next
                      count=1
                      while slow!=fast:
                          slow=slow.next
                          count+=1
                      return slow
        return 0

#Time Complexity=O(N)
#Space Complexity=O(1)
