#Linked List Cycle(Leetcode-141)

#Brute Force Solution

class Solution:
    def hasCycle(self, head: Optional[ListNode]) -> bool:
        temp=head
        my_set=set()
        while temp is not None:
            if temp in my_set:
               return true
            my_set.append(temp)
            temp=temp.next
       return False

#Time Complexity=O(N)
#Space Complexity=O(N)

#Optimal Solution

class Solution:
    def hasCycle(self, head: Optional[ListNode]) -> bool:
       slow=head
       fast=head
       while fast  is not Non and fast.next is not None:
            slow=slow.next
            fast=fast.next.next
            if slow==fast:
                return True
       return False

#Time Complexity=O(N)
#Space Complexity=O(1)
