#Linked List Cycle II(Leetcode-142)

#Brute Force solution
class Solution:
    def detectCycle(self, head: Optional[ListNode]) -> Optional[ListNode]:
       temp=head
       my_set=set()
       while temp is not None:
           if temp in my_set:
              return temp
           my_set.add(temp)
           temp=temp.next
       return None

#Time Complexity=O(N)
#Space Complexity=O(N)

#Optimal Solution

class Solution:
    def detectCycle(self, head: Optional[ListNode]) -> Optional[ListNode]:
      slow=head
      fast=head
      while fast is not None and fast.next is not None:
         slow=slow.next
         fast=fast.next.next
         if slow==fast:
            slow=head
            while slow!=fast:
               slow=slow.next
               fast=fast.next
            return slow
      return None

#Time Complexity=O(N)
#Space Complexity=O(1)

