#Longest Consecutive Sequence(Leetcode-128)

nums=list(map(int,input().split()))
ex:nums=[1,99,101,98,2,5,3,99,100]
n=len(nums)

#Brute Force Solution

max_count=0
for i in range(0,n):
   num=nums[i]
   count=1
   while num+1 in nums:
     count+=1
     num=num+1
   max_count=max(max_count,count)
return max_count

Time Complexity=O(N**2)
Space Complexity=O(1)

#Better Solution

last_smaller=float("-inf")
count=0
longest=0
nums.sort()
for i in range(0,n):
    num=nums[i]
    if num-1==last_smaller:
         count+=1
         last_smaller=num
    elif num!=last_smaller:
          count+=1
          last_smaller=num
    longest=max(longest,count)
return longest

Time Complexity=O(N log N+N)
Space Complexity=O(1)

#Optimal Solution

my_set=set()
longest=0
for i in range(0,n):
   my_set.add(nums[i])
for num in my_set:
    if num-1 not in my_set:
         x=num
         count=1
         while x+1 in my_set:
             count+=1
             x+=1
         longest=max(longest,count)
return longest

Time Compplexity=O(N+N+N)=O(3N)
Space Complexity=O(N)
